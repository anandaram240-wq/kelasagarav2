{
  "rewrites": [
    { "source": "/booking-detail", "destination": "/booking-detail.html" },
    { "source": "/chat",           "destination": "/chat.html" },
    { "source": "/hirer",          "destination": "/hirer-dashboard.html" },
    { "source": "/worker",         "destination": "/worker-dashboard.html" },
    { "source": "/admin",          "destination": "/admin-login.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
